# AdminPlus Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ===========================================
# Database Configuration
# ===========================================
DB_URL=jdbc:postgresql://127.0.0.1:5432/adminplus
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
DB_POOL_MAX=20
DB_POOL_MIN=5

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ===========================================
# JWT Configuration
# ===========================================
# Production: Use a strong random secret (at least 256 bits)
# Development: JWT_DEV_SECRET is used when APP_ENV=dev
JWT_SECRET=your_jwt_secret_here_at_least_32_characters
JWT_DEV_SECRET=dev_secret_key_for_testing_only

# ===========================================
# Application Environment
# ===========================================
APP_ENV=dev
SECURITY_JWT_USE_COOKIE=false
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ===========================================
# Initial Configuration
# ===========================================
INIT_DEFAULT_PASSWORD=admin123

# ===========================================
# Virus Scan (ClamAV)
# ===========================================
VIRUS_SCAN_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ===========================================
# File Storage Configuration
# ===========================================
FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_PATH=uploads
FILE_STORAGE_LOCAL_PREFIX=/uploads

# MinIO Configuration (if FILE_STORAGE_TYPE=minio)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_NAME=adminplus
MINIO_ACCESS_DOMAIN=
MINIO_SECURE=false

# ===========================================
# Log Storage Configuration
# ===========================================
LOG_STORAGE_MODE=DATABASE
LOG_CLEANUP_ENABLED=false
LOG_RETENTION_DAYS=90

# Elasticsearch (if LOG_STORAGE_MODE=elasticsearch)
LOG_ES_ENABLED=false
LOG_ES_URLS=http://localhost:9200
LOG_ES_USERNAME=
LOG_ES_PASSWORD=
LOG_ES_INDEX_PREFIX=adminplus-log